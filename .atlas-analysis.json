  "keyFeatures": [
    "Automated credential extraction from websites",
    "Database schema discovery and enumeration",
    "Row-Level Security (RLS) policy testing",
    "RPC function discovery and testing",
    "Interactive HTML reports",
    "Data dumping from exposed tables",
    "JWT token analysis",
    "Multiple output formats (console, JSON, HTML)"
  ],
  "publicApiSurface": [
    "analyze(client, url, key, options)",
    "extractFromUrl(url)",
    "dumpTable(client, schema, table, limit)",
    "callRPC(client, schema, rpcName, args, options)",
    "getSchemas(client)",
    "getTables(client, schema)",
    "getRPCs(client, schema)",
    "testTablesRead(client, schema, tables)"
  ]
